# Public page. TLS terminates at Caddy; this process must remain loopback-only.
PAGE_TLS=0
PAGE_HOST=127.0.0.1
PAGE_PORT=8088
PAGE_PUBLIC_ORIGIN=https://wttest.quicast.de

# Runtime matrix defaults. The public page exposes all eight response shapes.
WT_TARGET_BASE=https://wttest.quicast.de:9446
WT_TARGET_CERT=/etc/quicast/wttest/wttest.quicast.de.crt
WT_DEFAULT_TIMEOUT_MS=5000
WT_BETWEEN_CASES_MS=150
WT_DEFAULT_PATHS=/wt/basic,/wt/protocol,/wt/capsule,/wt/init,/wt/draft,/wt/h3-token,/wt/yggdrasil,/wt/auto
WT_DEFAULT_MODE=exhaustive
WT_AUTORUN=0

# Retain one anonymous aggregate snapshot per browser family and a bounded log
# containing only material metric changes. No raw UA, IP, URL, or error text is
# written to this file.
WT_RESULTS_ENABLED=1
WT_RESULTS_FILE=/var/lib/quicast-wttest/browser-results.json
WT_RESULTS_MAX_CHANGES=100

# Public UDP/H3 listener.
WT_LISTEN_HOST=::
WT_LISTEN_PORT=9446
WT_CERT=/etc/quicast/wttest/wttest.quicast.de.crt
WT_KEY=/etc/quicast/wttest/wttest.quicast.de.key
WT_IDLE_TIMEOUT=60
WT_MAX_DATA=8388608
WT_MAX_STREAM_DATA=8388608
WT_MAX_DATAGRAM_FRAME_SIZE=65536
WT_SETTINGS_PROFILE=yggdrasil
WT_WEBTRANSPORT_MAX_SESSIONS=1024
WT_RESET_STREAM_AT=1
WT_FLUSH_SETTINGS_ON_NEGOTIATE=1
WT_RETRY=0
WT_QUANTUM_READINESS=0
WT_VERBOSE=0

# Keep packet traces and TLS secrets disabled unless actively debugging.
WT_QLOG_DIR=
WT_SECRETS_LOG=

# Certificate handoff. With empty explicit source paths, the sync job finds the
# newest certificate in Caddy's data directory.
WT_CERT_HOST=wttest.quicast.de
WT_CADDY_CERT_STORE=/var/lib/caddy/.local/share/caddy/certificates
WT_CERT_SOURCE_CERT=
WT_CERT_SOURCE_KEY=
WT_CERT_MIN_VALID_SECONDS=3600

# Node-local real-H3 health check.
WT_HEALTH_CONNECT_HOST=::1
WT_HEALTH_CA_FILE=
WT_HEALTH_INSECURE=0
